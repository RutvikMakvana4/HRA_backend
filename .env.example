# Runtime
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug


CORS_ORIGINS=http://localhost:5173

# Postgres (matches docker-compose)
DATABASE_URL=postgres://hra:hra@localhost:5432/hra
DATABASE_POOL_MAX=10
DATABASE_SSL=false

# Redis (matches docker-compose)
REDIS_URL=redis://localhost:6379

# AWS / SQS — LocalStack for local dev
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
# Point at LocalStack locally; leave empty in real AWS to use the default endpoint.
SQS_ENDPOINT=http://localhost:4566
SQS_DEFAULT_QUEUE_URL=http://localhost:4566/000000000000/hra-default


PLAYER_IMAGES_ENABLED=false
S3_BUCKET=
# CloudFront domain or bucket public URL, no trailing slash. URL = ${S3_PUBLIC_BASE_URL}/players/<sha>.png
S3_PUBLIC_BASE_URL=
# Set only for LocalStack / custom endpoints; leave empty in real AWS.
S3_ENDPOINT=http://localhost:4566

# Auth.
# Access tokens are RS256 JWTs. Provide a PEM keypair (from Secrets Manager in real envs); if
# both are empty, the auth module generates an EPHEMERAL dev keypair at boot (tokens won't
# survive a restart). Generate a dev pair (do NOT commit real keys):
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out jwt-private.pem
#   openssl rsa -in jwt-private.pem -pubout -out jwt-public.pem
# Then set as single lines with literal \n, e.g. JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...".
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_KID=dev
# Still required by the env schema (reserved); access tokens use the RS256 keys above.
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-characters
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-chars
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# Email (Brevo transactional API) — auth OTP delivery. Optional in dev/test: when BREVO_API_KEY is
# blank, EmailService logs and the API returns `debugOtp` instead of sending. In production it is
# required and a failed send surfaces as an error. Load the key from Secrets Manager in real envs —
# never commit it. BREVO_SENDER_EMAIL must be a sender verified in the Brevo dashboard.
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=HRA

# Admin MFA. Leave true in any shared/staging env; production ALWAYS enforces it regardless.
# Set to false for LOCAL DEV ONLY to skip the TOTP step (password-only admin login).
ADMIN_MFA_REQUIRED=true

# Cache / locks
CACHE_VERSION=v1

# Superadmin seed (`pnpm db:seed`). If unset, dev defaults are used:
#   admin@hra.local / ChangeMe!Superadmin2026
# The account is seeded as mfa_pending — MFA is enrolled on first login. Set REAL values in any
# non-dev environment; never commit production credentials.
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=

# ─────────────────────────────────────────────────────────────────────────────
# GoalServe feed (powers the Markets board: events, odds, projections, results).
# The KEY is the only credential and lives in the URL PATH — never log it, load from
# Secrets Manager in real envs. The ingestion cron runs in the WORKER process (`pnpm worker`)
# and only fires when GOALSERVE_POLL_ENABLED=true AND GOALSERVE_KEY is set.
#   1. Paste your GoalServe key below.
#   2. Set GOALSERVE_POLL_ENABLED=true.
#   3. Run `pnpm worker` (separate process from the API) to start polling.
# NOTE: odds/projection feed paths per sport may need tuning — see src/modules/ingestion/feed/
# sport-config.ts (the oddsPath/oddsCat TODOs) once you can hit the API with your key.
GOALSERVE_KEY=
GOALSERVE_BASE_URL=http://www.goalserve.com/getfeed
GOALSERVE_POLL_ENABLED=false

# Shared secret for verifying inbound GoalServe webhook pushes (HMAC-SHA256 over the raw body, sent
# in the `x-goalserve-signature` header). Leave blank in dev to accept unsigned test posts; REQUIRED
# in production (unsigned webhooks are rejected). POST endpoint: /v1/webhooks/goalserve
GOALSERVE_WEBHOOK_SECRET=

# In-play WebSocket (live odds/scores push) — runs in the WORKER process only. Set the ws(s):// URL
# and enable; auth uses GOALSERVE_KEY. Alternative to the in-play HTTP poll. If updated_ts goes stale
# (>30s) the consumer suspends all in-play markets per GoalServe's heartbeat rule.
GOALSERVE_INPLAY_WS_ENABLED=false
GOALSERVE_INPLAY_WS_URL=
