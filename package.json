{
  "name": "HRA_backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "worker": "nest start --watch --entryFile worker",
    "worker:start": "node dist/worker.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"{src,test}/**/*.{ts,json}\"",
    "format:check": "prettier --check \"{src,test}/**/*.{ts,json}\"",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:e2e": "jest --config ./test/jest-e2e.json --passWithNoTests",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:backfill-images": "tsx src/db/backfill-player-images.ts",
    "db:check": "drizzle-kit check",
    "db:studio": "drizzle-kit studio",
    "up": "docker compose up -d",
    "down": "docker compose down",
    "prepare": "true"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1068.0",
    "@aws-sdk/client-sqs": "3.1068.0",
    "@aws-sdk/s3-request-presigner": "3.1068.0",
    "@nestjs/common": "11.1.26",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.26",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/platform-express": "11.1.26",
    "@nestjs/schedule": "6.1.3",
    "@nestjs/swagger": "11.4.4",
    "argon2": "0.44.0",
    "drizzle-orm": "0.45.2",
    "helmet": "8.2.0",
    "ioredis": "5.11.1",
    "nestjs-pino": "4.6.1",
    "nestjs-zod": "5.4.0",
    "pg": "8.21.0",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "undici": "8.5.0",
    "zod": "4.4.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@nestjs/cli": "11.0.23",
    "@nestjs/schematics": "11.1.0",
    "@nestjs/testing": "11.1.26",
    "@testcontainers/postgresql": "12.0.2",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/node": "24.13.2",
    "@types/pg": "8.20.0",
    "@types/supertest": "^7.2.0",
    "dotenv": "17.4.2",
    "drizzle-kit": "0.31.10",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.6.0",
    "jest": "30.4.2",
    "pino-pretty": "13.1.3",
    "prettier": "3.8.4",
    "supertest": "^7.2.2",
    "testcontainers": "12.0.2",
    "ts-jest": "29.4.11",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.61.0"
  }
}
